# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL from: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=""

# Anon / public key from: Supabase Dashboard → Project Settings → API → Project API keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# ─── Stellar / Soroban Escrow Contract ───────────────────────────────────────
# Deployed escrow contract address on Testnet (C... address)
NEXT_PUBLIC_ESCROW_CONTRACT_ID_TESTNET=""

# Deployed escrow contract address on Mainnet (C... address)
NEXT_PUBLIC_ESCROW_CONTRACT_ID_MAINNET=""

# USDC Stellar Asset Contract (SAC) address on Testnet
# Deploy with: stellar contract asset deploy --asset USDC:GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5 --network testnet
NEXT_PUBLIC_USDC_SAC_TESTNET=""

# USDC Stellar Asset Contract (SAC) address on Mainnet
NEXT_PUBLIC_USDC_SAC_MAINNET=""

# PPHP Stellar Asset — Simulated Philippine Peso
# On testnet, the platform account acts as issuer. On mainnet, use a separate locked key.
NEXT_PUBLIC_PPHP_ISSUER_MAINNET=""

# MariTrade platform Stellar secret key (server-side only — never expose to client)
# Used by API routes to co-sign PRE_DEPARTURE cancellations and advance_stage calls
PLATFORM_STELLAR_SECRET_KEY=""

# Active network: "testnet" or "mainnet"
NEXT_PUBLIC_STELLAR_NETWORK="testnet"

# ─── AIS Vessel Tracking (Phase 3) ───────────────────────────────────
# Get a free key at https://aisstream.io
# IMPORTANT: this key is used ONLY by scripts/ais-worker.ts, a standalone
# process run separately (`npm run ais-worker`) — NOT by any Next.js API
# route, since aisstream.io is a persistent WebSocket stream that can't be
# called from inside a serverless function. See that script's header comment
# and lib/verification/ais-tracking.ts for the full explanation.
AISSTREAM_API_KEY=""

# Required by scripts/ais-worker.ts to write to the ais_vessel_positions
# cache table (bypasses RLS, same key used server-side elsewhere).
SUPABASE_SERVICE_ROLE_KEY=""

# ─── Proactive Delay Monitoring (Phase 4) ─────────────────────────
# Shared secret that /api/cron/delay-monitor requires on every request as
# "Authorization: Bearer <CRON_SECRET>". Vercel Cron sends this header
# automatically on every scheduled invocation once this var is set in your
# Vercel project — see vercel.json for the schedule. Without this set, the
# route refuses to run (fails closed, not open).
CRON_SECRET=""

# Optional — port congestion / customs backlog data providers for
# app/api/cron/delay-monitor. There is no single standard public API for
# either signal (typically paid, provider-specific feeds — terminal
# operators, customs-broker data, freight-visibility platforms like
# project44/FourKites, etc.). Leave these unset and the delay monitor runs
# on schedule but never finds anything to alert on — see
# lib/delay-signals.ts's header comment for how to wire in a real provider.
PORT_CONGESTION_API_URL=""
PORT_CONGESTION_API_KEY=""
CUSTOMS_BACKLOG_API_URL=""
CUSTOMS_BACKLOG_API_KEY=""
