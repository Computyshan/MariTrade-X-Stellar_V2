# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL from: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=""

# Anon / public key from: Supabase Dashboard → Project Settings → API → Project API keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# ─── Stellar / Soroban Escrow Contract ───────────────────────────────────────
# Deployed escrow contract address on Testnet (C... address)
NEXT_PUBLIC_ESCROW_CONTRACT_ID_TESTNET=""

# Deployed escrow contract address on Mainnet (C... address)
NEXT_PUBLIC_ESCROW_CONTRACT_ID_MAINNET=""

# USDC Stellar Asset Contract (SAC) address on Testnet
# Deploy with: stellar contract asset deploy --asset USDC:GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5 --network testnet
NEXT_PUBLIC_USDC_SAC_TESTNET=""

# USDC Stellar Asset Contract (SAC) address on Mainnet
NEXT_PUBLIC_USDC_SAC_MAINNET=""

# PPHP Stellar Asset — Simulated Philippine Peso
# On testnet, the platform account acts as issuer. On mainnet, use a separate locked key.
NEXT_PUBLIC_PPHP_ISSUER_MAINNET=""

# MariTrade platform Stellar secret key (server-side only — never expose to client)
# Used by API routes to co-sign PRE_DEPARTURE cancellations and advance_stage calls
PLATFORM_STELLAR_SECRET_KEY=""

# Active network: "testnet" or "mainnet"
NEXT_PUBLIC_STELLAR_NETWORK="testnet"
